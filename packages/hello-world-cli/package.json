{
  "name": "hello-world-cli",
  "version": "0.1.0",
  "description": "A sample CLI that says hello world",
  "type": "module",
  "bin": {
    "hello-world": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "yarn workspace hello-world-util build && tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "hello-world-util": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.2",
    "typescript": "*"
  }
}
